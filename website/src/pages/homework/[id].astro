---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const homeworks = await getCollection('homework');
  return homeworks.map((hw) => ({
    params: { id: hw.id },
    props: { hw },
  }));
}

const { hw } = Astro.props;
const { Content } = await render(hw);
---

<BaseLayout title={hw.data.title}>
  <section class="max-w-3xl mx-auto px-4 py-10">
    <div class="mb-6">
      <span class="text-sm text-[var(--sogang-red)] font-semibold">{hw.data.chapter}장</span>
      <h1 class="text-3xl font-bold mt-1 text-[var(--sogang-red)]">{hw.data.title}</h1>
      {hw.data.dueDate && <p class="text-sm text-gray-500 mt-2">마감: {hw.data.dueDate}</p>}
    </div>
    <article class="prose prose-lg max-w-none">
      <Content />
    </article>
  </section>
</BaseLayout>

<script>
  // KaTeX rendering for homework pages
  import katex from 'katex';

  document.querySelectorAll('.prose').forEach((el) => {
    // Display math
    el.innerHTML = el.innerHTML.replace(/\$\$([\s\S]*?)\$\$/g, (_, tex: string) => {
      try {
        return katex.renderToString(tex.trim(), { displayMode: true, throwOnError: false });
      } catch { return tex; }
    });
    // Inline math
    el.innerHTML = el.innerHTML.replace(/\$([^\$\n]+?)\$/g, (_, tex: string) => {
      try {
        return katex.renderToString(tex.trim(), { displayMode: false, throwOnError: false });
      } catch { return tex; }
    });
  });
</script>
