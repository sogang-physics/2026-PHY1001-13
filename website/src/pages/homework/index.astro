---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const homeworks = (await getCollection('homework')).sort((a, b) => a.data.chapter - b.data.chapter);
---

<BaseLayout title="숙제">
  <section class="max-w-4xl mx-auto px-4 py-10">
    <h1 class="text-3xl font-bold mb-8 text-[var(--sogang-red)]">숙제</h1>

    {homeworks.length === 0 ? (
      <p class="text-gray-500">숙제가 아직 등록되지 않았습니다.</p>
    ) : (
      <div class="grid gap-4">
        {homeworks.map((hw) => (
          <a
            href={`${base}homework/${hw.id}/`}
            class="block bg-white rounded-xl shadow-sm border border-[#8B0029]/10 p-5 hover:shadow-md hover:border-[#8B0029]/30 transition-all"
          >
            <div class="flex items-center justify-between">
              <div>
                <span class="text-xs text-[var(--sogang-red)] font-semibold">
                  {hw.data.chapter}장
                </span>
                <h2 class="text-lg font-bold mt-1">{hw.data.title}</h2>
                {hw.data.dueDate && (
                  <p class="text-sm text-gray-500 mt-1">마감: {hw.data.dueDate}</p>
                )}
              </div>
              <span class="text-2xl text-[var(--sogang-red)]/30">→</span>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
