---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const lectures = (await getCollection('lectures')).sort((a, b) => a.data.week - b.data.week);
---

<BaseLayout title="강의 자료">
  <section class="max-w-4xl mx-auto px-4 py-10">
    <h1 class="text-3xl font-bold mb-8 text-[var(--sogang-red)]">강의 자료</h1>

    {lectures.length === 0 ? (
      <p class="text-gray-500">강의 자료가 아직 준비되지 않았습니다.</p>
    ) : (
      <div class="grid gap-4">
        {lectures.map((lecture) => (
          <a
            href={`${base}lectures/${lecture.id}/`}
            class="block bg-white rounded-xl shadow-sm border border-[#8B0029]/10 p-5 hover:shadow-md hover:border-[#8B0029]/30 transition-all"
          >
            <div class="flex items-center justify-between">
              <div>
                <span class="text-xs text-[var(--sogang-red)] font-semibold">
                  {lecture.data.week}주차 · {lecture.data.chapters}
                </span>
                <h2 class="text-lg font-bold mt-1">{lecture.data.title}</h2>
                <p class="text-sm text-gray-500 mt-1">{lecture.data.topics}</p>
              </div>
              <span class="text-2xl text-[var(--sogang-red)]/30">→</span>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
