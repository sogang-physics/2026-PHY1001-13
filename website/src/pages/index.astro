---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

const schedule = [
  { week: 1, chapters: '1, 2, 3장', topic: '기본 물리량, 직선 운동, 벡터' },
  { week: 2, chapters: '4, 5장', topic: '포물체 운동, 원운동, 뉴턴의 법칙' },
  { week: 3, chapters: '6, 7장', topic: '마찰, 항력, 일과 운동에너지' },
  { week: 4, chapters: '8, 9장', topic: '퍼텐셜에너지, 에너지 보존, 선운동량' },
  { week: 5, chapters: '10장', topic: '회전변수, 회전 운동에너지, 토크' },
  { week: 6, chapters: '11장', topic: '굴림운동, 강체의 각운동량' },
  { week: 7, chapters: '12장', topic: '평형, 탄성' },
  { week: 8, chapters: '', topic: '중간고사', exam: true },
  { week: 9, chapters: '13장', topic: '뉴턴의 중력 법칙, 케플러의 법칙' },
  { week: 10, chapters: '14, 15장', topic: '유체, 진동' },
  { week: 11, chapters: '15, 16장', topic: '진동, 파동' },
  { week: 12, chapters: '16, 17장', topic: '파동의 간섭, 도플러 효과' },
  { week: 13, chapters: '18장', topic: '온도, 열팽창, 열역학 제1법칙' },
  { week: 14, chapters: '19장', topic: '이상기체, 기체운동론' },
  { week: 15, chapters: '20장', topic: '엔트로피, 열역학 제2법칙' },
  { week: 16, chapters: '', topic: '기말고사', exam: true },
];
---

<BaseLayout title="홈">
  <!-- Hero -->
  <section class="bg-[var(--sogang-red)] text-white py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl font-bold mb-2">일반물리 I</h1>
      <p class="text-xl opacity-90">PHY1001 · 2026년 1학기 · 서강대학교</p>
      <div class="mt-8 flex justify-center gap-4 text-sm">
        <a href={`${base}lectures/`} class="bg-white text-[var(--sogang-red)] px-5 py-2 rounded-lg font-semibold hover:bg-gray-100">강의 자료</a>
        <a href={`${base}homework/`} class="border border-white px-5 py-2 rounded-lg hover:bg-white/10">숙제</a>
        <a href={`${base}simulations/`} class="border border-white px-5 py-2 rounded-lg hover:bg-white/10">시뮬레이션</a>
      </div>
    </div>
  </section>

  <!-- Info -->
  <section class="max-w-4xl mx-auto px-4 py-10">
    <div class="grid md:grid-cols-2 gap-8">
      <div class="bg-white rounded-xl shadow-sm border border-[#8B0029]/10 p-6">
        <h2 class="text-lg font-bold mb-4 text-[var(--sogang-red)]">강의 정보</h2>
        <table class="w-full text-sm">
          <tbody>
            <tr class="border-b border-[#8B0029]/10"><td class="py-2 font-medium w-24 text-[var(--sogang-red)]">담당</td><td>최영우</td></tr>
            <tr class="border-b border-[#8B0029]/10"><td class="py-2 font-medium text-[var(--sogang-red)]">시간</td><td>수, 금 15:00-16:15</td></tr>
            <tr class="border-b border-[#8B0029]/10"><td class="py-2 font-medium text-[var(--sogang-red)]">장소</td><td>F303C</td></tr>
            <tr class="border-b border-[#8B0029]/10"><td class="py-2 font-medium text-[var(--sogang-red)]">면담</td><td>월,화,목 10:00-12:00 (이메일 예약)</td></tr>
            <tr><td class="py-2 font-medium text-[var(--sogang-red)]">이메일</td><td>ywchoi02@sogang.ac.kr</td></tr>
          </tbody>
        </table>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-[#8B0029]/10 p-6">
        <h2 class="text-lg font-bold mb-4 text-[var(--sogang-red)]">교재 & 평가</h2>
        <p class="text-sm mb-3">
          <strong>교재:</strong> Principles of Physics, 12/E<br>
          (Resnick, Halliday, Walker)
        </p>
        <div class="text-sm">
          <strong>평가:</strong>
          <div class="flex gap-4 mt-1">
            <span class="bg-[#8B0029]/10 text-[var(--sogang-red)] px-3 py-1 rounded font-medium">중간 50%</span>
            <span class="bg-[#8B0029]/10 text-[var(--sogang-red)] px-3 py-1 rounded font-medium">기말 50%</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Schedule -->
  <section class="max-w-4xl mx-auto px-4 pb-16">
    <h2 class="text-2xl font-bold mb-6 text-[var(--sogang-red)]">주차별 수업 계획</h2>
    <div class="bg-white rounded-xl shadow-sm border border-[#8B0029]/10 overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-[var(--sogang-red)] text-white">
          <tr>
            <th class="px-4 py-3 text-left font-semibold w-16">주차</th>
            <th class="px-4 py-3 text-left font-semibold w-28">교재</th>
            <th class="px-4 py-3 text-left font-semibold">주제</th>
          </tr>
        </thead>
        <tbody>
          {schedule.map((s) => (
            <tr class:list={["border-t border-[#8B0029]/10", { "bg-[#8B0029]/5 font-semibold": s.exam }]}>
              <td class="px-4 py-2.5 font-medium text-[var(--sogang-red)]">{s.week}</td>
              <td class="px-4 py-2.5 text-gray-500">{s.chapters}</td>
              <td class="px-4 py-2.5">{s.topic}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</BaseLayout>
